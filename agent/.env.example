# ─────────────────────────────────────────────────────────────────────────────
# Backend agent environment variables (agent/.env for local dev)
# Copy this file to agent/.env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI (preferred for Azure deployments) ──────────────────────────
# When AZURE_OPENAI_ENDPOINT is set the agent uses Azure OpenAI with
# DefaultAzureCredential (Managed Identity or az login — no key needed).
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini

# ── OpenAI (alternative for local development) ──────────────────────────────
# When AZURE_OPENAI_ENDPOINT is NOT set the agent falls back to OpenAI.
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL_ID=gpt-4o-mini

# ── Server binding (optional, defaults shown) ────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
