# ============================================================
# deploy-config.env.example
# Configuration template for scripts/deploy.sh and deploy.ps1
#
# Usage:
#   cp scripts/deploy-config.env.example scripts/deploy-config.env
#   Fill in the values below, then run:
#     bash scripts/deploy.sh
#   Or on Windows:
#     pwsh scripts/deploy.ps1
# ============================================================

# --- Azure general ---
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_LOCATION=eastus

# --- Resource naming ---
RESOURCE_GROUP=rg-worldcup2026
ACR_NAME=acrworldcup2026            # must be globally unique, lowercase letters and digits only
CONTAINER_APP_ENV=cae-worldcup2026
CONTAINER_APP_NAME=ca-agent-worldcup2026
STATIC_WEB_APP_NAME=swa-worldcup2026

# --- Docker image ---
IMAGE_NAME=worldcup2026-agent       # image name inside the ACR

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
