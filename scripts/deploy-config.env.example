# --- Azure general ---
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_LOCATION=eastus

# --- Resource naming ---
RESOURCE_GROUP=rg-worldcup2026
STATIC_WEB_APP_NAME=swa-worldcup2026
